			<!-- - - - - - - - - - - - - - Page Wrapper - - - - - - - - - - - - - - - - -->
			<div class="secondary_page_wrapper">
				<div class="container" id="container_wrapper">
										<div class="row cn-page-row">
						<aside class="has_mega_menu cn-left-sidebar">
							<style>
    .cn-sidebar-box{width:100%!important;max-width:320px!important;box-sizing:border-box;margin:0!important;font-family:Roboto,Arial,sans-serif;}
    .cn-sidebar-card-main{background:#fff;border:1px solid #dbe7f3;border-radius:10px;overflow:hidden;box-shadow:0 10px 30px rgba(15,39,71,.10);}
    .cn-sidebar-title{display:flex;align-items:center;justify-content:space-between;background:linear-gradient(180deg,#005ebd,#004a9e);color:#fff;font-size:18px;font-weight:900;padding:15px 18px;margin:0;}
    .cn-sidebar-title i{display:none!important;}
    .cn-left-menu{margin:0!important;padding:0!important;background:#fff;list-style:none!important;border:0!important;box-shadow:none!important;overflow:visible!important;}
    .cn-left-menu>li{list-style:none!important;margin:0!important;padding:0!important;border-bottom:1px solid #e5edf6;position:relative;}
    .cn-left-menu>li:last-child{border-bottom:0;}
    .cn-left-menu>li>a{display:flex!important;align-items:center;justify-content:space-between;gap:10px;padding:12px 16px!important;color:#202b3c!important;text-decoration:none!important;font-size:13px!important;font-weight:700!important;line-height:1.22!important;background:#fff!important;transition:.16s ease;}
    .cn-left-menu>li>a:hover{background:#f1f7ff!important;color:#0053a6!important;}
    .cn-left-menu>li>a span{display:flex;align-items:center;gap:12px;min-width:0;}
    .cn-left-menu .cat-left-icon{display:inline-flex;align-items:center;justify-content:center;width:22px;min-width:22px;color:#006bd6;font-size:15px;}
    .cn-left-menu .cat-right-chevron{color:#a6b1bf;font-size:15px;transition:.16s ease;}
    .cn-left-menu>li>a:hover .cat-right-chevron{color:#0053a6;transform:translateX(2px);}
    .cn-left-menu .mega_menu{display:none;position:absolute;left:100%!important;top:0!important;min-width:360px;max-width:620px;padding:16px!important;background:#fff!important;border:1px solid #dbe7f3!important;border-radius:10px!important;box-shadow:0 12px 30px rgba(15,39,71,.14)!important;z-index:20000!important;}
    .cn-left-menu>li:hover .mega_menu{display:flex!important;gap:12px;}
    .cn-left-menu .mega_menu_item{flex:1;min-width:0;}
    .cn-left-menu .list_of_links{margin:0!important;padding:0!important;list-style:none!important;}
    .cn-left-menu .list_of_links li{list-style:none!important;margin:0!important;padding:0!important;}
    .cn-left-menu .list_of_links a{display:block!important;padding:8px 9px!important;border-radius:6px!important;color:#38465a!important;font-size:13px!important;font-weight:600!important;text-decoration:none!important;}
    .cn-left-menu .list_of_links a:hover{background:#eef6ff!important;color:#0053a6!important;}
    @media(max-width:900px){.cn-sidebar-card-main{margin-bottom:18px}.cn-left-menu .mega_menu{position:static!important;display:none!important;min-width:100%;max-width:100%;box-shadow:none!important;border:0!important;border-top:1px solid #e7eef6!important;border-radius:0!important}.cn-left-menu>li:hover .mega_menu{display:block!important}.cn-sidebar-title{font-size:19px;padding:17px 18px}.cn-left-menu>li>a{font-size:14px!important;padding:13px 16px!important;}}
