<script>
(function(){
    // Control de Whatsapp
    document.addEventListener('click', function(e){
        var btn = e.target.closest ? e.target.closest('.cn-store-whatsapp') : null;
        var panel = document.getElementById('cnSalesPanel');
        if (btn && panel) {
            e.preventDefault();
            panel.classList.toggle('is-open');
            // Cerrar login panel si estaba abierto
            var lp = document.getElementById('cnLoginPanel');
            if (lp) lp.classList.remove('is-open');
            return;
        }
        if (panel && (!e.target.closest || !e.target.closest('.cn-sales-wrap:not(.cn-login-wrap)'))) {
            panel.classList.remove('is-open');
        }
    });

    // Control de Login Panel (Mi Cuenta dropdown)
    document.addEventListener('click', function(e){
        var btn = e.target.closest ? e.target.closest('.cn-login-wrap > .cn-header-btn') : null;
        var panel = document.getElementById('cnLoginPanel');
        if (btn && panel) {
            e.preventDefault();
            panel.classList.toggle('is-open');
            // Cerrar sales panel si estaba abierto
            var sp = document.getElementById('cnSalesPanel');
            if (sp) sp.classList.remove('is-open');
            return;
        }
        if (panel && (!e.target.closest || !e.target.closest('.cn-login-wrap'))) {
            panel.classList.remove('is-open');
        }
    });

    // Control de Menu Movil (Hamburguesa)
    document.addEventListener('click', function(e){
        var trigger = e.target.closest ? e.target.closest('.cn-mobile-menu-trigger') : null;
        var menu = document.getElementById('cnMobileMenu');
        if (trigger && menu) {
            e.preventDefault();
            menu.classList.toggle('is-open');
            var icon = trigger.querySelector('i');
            if (icon) {
                if (menu.classList.contains('is-open')) {
                    icon.className = 'fa fa-times';
                } else {
                    icon.className = 'fa fa-bars';
                }
            }
            return;
        }
        // Cerrar al hacer click fuera
        if (menu && menu.classList.contains('is-open') && (!e.target.closest || (!e.target.closest('.cn-mobile-menu-trigger') && !e.target.closest('.cn-mobile-menu-dropdown')))) {
            menu.classList.remove('is-open');
            var triggerBtn = document.querySelector('.cn-mobile-menu-trigger i');
            if (triggerBtn) triggerBtn.className = 'fa fa-bars';
        }
    });

    // Control de Dropdown de Usuario en Desktop
    document.addEventListener('click', function(e){
        var trigger = e.target.closest ? e.target.closest('.cn-dropdown-wrapper > button') : null;
        var dropdown = e.target.closest ? e.target.closest('.cn-dropdown-wrapper') : null;
        
        if (trigger && dropdown) {
            e.preventDefault();
            dropdown.classList.toggle('is-active');
            return;
        }
        
        var activeDropdown = document.querySelector('.cn-dropdown-wrapper.is-active');
        if (activeDropdown && (!dropdown || activeDropdown !== dropdown)) {
            activeDropdown.classList.remove('is-active');
        }
    });

    // Control del Mini Carrito de Cotización
    document.addEventListener('click', function(e){
        var cartBtn = e.target.closest ? e.target.closest('#open_shopping_cart') : null;
        var cartContainer = document.getElementById('responsive_car');
        if (cartBtn) {
            e.preventDefault();
            e.stopPropagation();
            cartBtn.classList.toggle('active');
            return;
        }
        // Cerrar carrito al click fuera
        if (cartContainer && (!e.target.closest || !e.target.closest('#responsive_car'))) {
            var openBtn = document.getElementById('open_shopping_cart');
            if (openBtn) openBtn.classList.remove('active');
        }
    });

    document.addEventListener('keyup', function(e){
        if (e.key === 'Escape') {
            var panel = document.getElementById('cnSalesPanel');
            if (panel) panel.classList.remove('is-open');

            var loginPanel = document.getElementById('cnLoginPanel');
            if (loginPanel) loginPanel.classList.remove('is-open');
            
            var menu = document.getElementById('cnMobileMenu');
            if (menu) {
                menu.classList.remove('is-open');
                var triggerBtn = document.querySelector('.cn-mobile-menu-trigger i');
                if (triggerBtn) triggerBtn.className = 'fa fa-bars';
            }
            
            var dropdown = document.querySelector('.cn-dropdown-wrapper.is-active');
            if (dropdown) dropdown.classList.remove('is-active');

            // Cerrar mini carrito
            var openBtn = document.getElementById('open_shopping_cart');
            if (openBtn) openBtn.classList.remove('active');
        }
    });

    // ── Login Panel: Cambiar vistas ──
    window.cnLpShow = function(viewName) {
        var views = document.querySelectorAll('.cn-lp-view');
        for (var i = 0; i < views.length; i++) {
            views[i].classList.remove('cn-lp-active');
        }
        var target = document.getElementById('cnLp' + viewName);
        if (target) target.classList.add('cn-lp-active');
    };

    // ── Login Panel: Autocompletar RUC/DNI ──
    var cnLpDocTimer;
    var cnLpDocInput = document.getElementById('cnLpDoc');
    if (cnLpDocInput) {
        cnLpDocInput.addEventListener('input', function() {
            var val = this.value.replace(/[^0-9]/g, '');
            this.value = val;
            var statusDiv = document.getElementById('cnLpDocStatus');
            if (statusDiv) statusDiv.innerHTML = '';

            if (val.length === 11 || val.length === 8) {
                var docType = val.length === 11 ? 'RUC' : 'DNI';
                if (statusDiv) statusDiv.innerHTML = '<p class="cn-lp-doc-msg" style="color:#a8d4ff;"><i class="fa fa-spinner fa-spin"></i> Buscando ' + docType + '...</p>';
                clearTimeout(cnLpDocTimer);
                cnLpDocTimer = setTimeout(function() {
                    var xhr = new XMLHttpRequest();
                    xhr.open('GET', '/app/buscar_cliente.php?documento=' + val + '&ruc=' + val, true);
                    xhr.onload = function() {
                        if (statusDiv) statusDiv.innerHTML = '';
                        try {
                            var res = JSON.parse(xhr.responseText);
                            if (res.success) {
                                if (statusDiv) statusDiv.innerHTML = '<p class="cn-lp-doc-msg" style="color:#4ade80;"><i class="fa fa-check-circle"></i> Cliente verificado</p>';
                                var f = res.cliente;
                                if (f.razon_social) document.getElementById('cnLpEmpresa').value = f.razon_social;
                                if (f.direccion) document.getElementById('cnLpDireccion').value = f.direccion;
                                if (f.contacto) document.getElementById('cnLpNombre').value = f.contacto;
                                if (f.celular) document.getElementById('cnLpCelular').value = f.celular;
                                if (f.email) document.getElementById('cnLpEmail').value = f.email;
                            } else {
                                if (statusDiv) statusDiv.innerHTML = '<p class="cn-lp-doc-msg" style="color:rgba(255,255,255,.5);"><i class="fa fa-info-circle"></i> No registrado. Complete manualmente.</p>';
                            }
                        } catch(e) {}
                    };
                    xhr.send();
                }, 350);
            }
        });
    }
})();
</script>
<script src="/web3/js/busqueda_predictiva.js?v=20260610-headerfix"></script>

