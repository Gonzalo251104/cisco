        <style>
            :root {
                --cn-primary: #005bd7;      /* Azul Moderno */
                --cn-primary-hover: #044cb5;/* Azul hover */
                --cn-navy: #0070B8;         /* Azul principal */
                --cn-text-color: #10264d;   /* Texto principal */
                --cn-muted-color: #50627e;  /* Texto secundario */
                --cn-border-color: #dfe7f2; /* Bordes/separadores */
                --cn-bg: #f6f9fd;           /* Fondo general */
            }
            body.front_page{background:var(--cn-bg)!important;color:var(--cn-text-color);font-family:Roboto,Arial,sans-serif;}
            body, input, button, select, textarea { font-family: Roboto, Arial, sans-serif; }
            .wide_layout{background:var(--cn-bg)!important;overflow-x:hidden!important;}
            .secondary_page_wrapper{background:linear-gradient(180deg,#f8fbff 0%,var(--cn-bg) 100%)!important;padding:14px 24px 12px!important;margin:0!important;}
            #container_wrapper{width:100%!important;max-width:100%!important;margin:0!important;padding:0!important;box-sizing:border-box;}
            .cn-page-row{display:flex!important;gap:24px!important;align-items:flex-start!important;margin:0!important;width:100%!important;max-width:100%!important;box-sizing:border-box;}
            .cn-left-sidebar{flex:0 0 320px!important;width:320px!important;max-width:320px!important;min-width:320px!important;float:none!important;margin:0!important;padding:0!important;box-sizing:border-box!important;}
            .cn-main-content{flex:1 1 auto!important;width:auto!important;max-width:calc(100% - 344px)!important;min-width:0!important;float:none!important;background:transparent!important;border:0!important;border-radius:0!important;box-shadow:none!important;padding:0!important;margin:0!important;box-sizing:border-box!important;}
            .section_offset{margin-bottom:0!important;}
            .social_feeds,ul.social_feeds,.social_feeds li,.social_feeds a,a[href*="api.whatsapp.com"][style*="position: fixed"],a[href*="wa.me"][style*="position: fixed"]{display:none!important;visibility:hidden!important;}
            a{transition:.16s ease;}
            @media(max-width:1200px){.secondary_page_wrapper{padding:16px 16px 12px!important}.cn-page-row{gap:20px!important}.cn-left-sidebar{flex-basis:300px!important;width:300px!important;min-width:300px!important;max-width:300px!important}.cn-main-content{max-width:calc(100% - 320px)!important}}
            @media(max-width:900px){.cn-page-row{display:block!important}.cn-left-sidebar{width:100%!important;max-width:100%!important;min-width:0!important;margin-bottom:20px!important}.cn-main-content{max-width:100%!important;width:100%!important}.secondary_page_wrapper{padding:12px 12px 10px!important}}
        .cn-fix-gap-footer-2026{} .cn-main-content{min-height:0!important;} #container_wrapper{padding-bottom:0!important;}
        </style>

		<script src="/web3/js/modernizr.js"></script>
