		<script type="text/javascript">
		$(function(){
			$( "#sugerencia_form" ).validate({
		        ignore: [],
		        rules: {
		            'sf_name': {
		              	required: true,
		                minlength: 2
		            },
		            'sf_email': {
		                required: true, 
		                email: true
		            },
		            'sf_message': {
		                required: true,
		                minlength: 6
		            }
		        }, 
		        messages: {
		            'sf_name': {
		                required: "Ingrese su nombre",
		                minlength: "Ingrese más de 1 caracter"
		            },
		            'sf_email': {
		                required: "Ingrese su email",
		                email: "Ingrese un email válido"
		            },
		            'sf_message': {
		                required: "Ingrese su mensaje.",
		                minlength: "Ingrese más de 5 caracteres"
		            }
		        },
		        submitHandler: function(form) {
			    	$.ajax({
			    		method: "POST",
					  	url: form.action,
					  	data: {sf_name: form.sf_name.value, sf_email: form.sf_email.value, sf_message: form.sf_message.value, 'g-recaptcha-response': grecaptcha.getResponse(), sf_enviar: 'enviar'}
					}).done(function(data) {
						if(data == 'invalid-captcha'){
							$('<div class="alert_box error"><b>Complete el captcha!</b>.<button class="close"></button></div>').appendTo('#mensaje_send');
						}else{
							if(data == '1'){
								form.reset();
								grecaptcha.reset()
								$('<div class="alert_box success"><b>Gracias por su sugerencia!</b>.<button class="close"></button></div>').appendTo('#mensaje_send');
							}else{
								$('<div class="alert_box error"><b>Error al enviar!</b>.<button class="close"></button></div>').appendTo('#mensaje_send');
							}
						}
					  	
					  	$('#mensaje_send').show();
					  	setTimeout(function(){ $('#mensaje_send').hide(); $('#mensaje_send').html(''); }, 3000);
					});
					
			  	}
		    });
		});
		</script>
		<script>
  $(function() {
    // Cargar mini carrito al iniciar la página
    loadMinicotizacion(false);

    $( 'button[rel=add_to_cart]' ).click(function(){
      var btn = $(this);
      var prodId = btn.attr('producto_id');
      var cantInput = $('#cantidad_' + prodId);
      var cantidad = cantInput.length ? cantInput.val() : 1;
      if (!cantidad || cantidad < 1) cantidad = 1;

      // Feedback visual en el botón
      var textoOriginal = btn.html();
      btn.prop('disabled', true).html('<i class="fa fa-spinner fa-spin"></i> Agregando...');

      $.ajax({
        method: "POST",
        url: "/accion_cotizacion.php?action=add&id=" + prodId + "&cantidad=" + cantidad
      }).done(function(data) {
        console.log(data);
        // Restaurar botón
        btn.prop('disabled', false).html(textoOriginal);

        // Mostrar notificación toast
        cnShowCartToast('Producto agregado a la cotización');

        // Recargar mini carrito
        loadMinicotizacion(true);
      }).fail(function(){
        btn.prop('disabled', false).html(textoOriginal);
        cnShowCartToast('Error al agregar. Intenta nuevamente.', true);
      });
    });
  });

  function cnShowCartToast(msg, isError) {
    // Remover toast anterior si existe
    $('.cn-cart-toast').remove();
    var iconClass = isError ? 'fa fa-exclamation-circle' : 'fa fa-check-circle';
    var borderColor = isError ? '#e53935' : '#079b3f';
    var toast = $('<div class="cn-cart-toast" style="border-left-color:' + borderColor + '"><i class="' + iconClass + '" style="color:' + borderColor + '"></i><span>' + msg + '</span></div>');
    $('body').append(toast);
    setTimeout(function(){ toast.fadeOut(300, function(){ toast.remove(); }); }, 3000);
  }

  function loadMinicotizacion(show){
    show || ( show = false );
    $.ajax({
      method: "POST",
      url: "/ver_cotizacion.php"
    }).done(function(data) {
      $('#responsive_car').html(data);
      setMiniCotizacion();
      if(show != false){
        showMiniCotizacion();
      }
    });
  }

  function setMiniCotizacion(){
    $( 'button[rel=eliminar]' ).click(function(){
        $.ajax({
          method: "GET",
          url: "/accion_cotizacion.php?action=delete&id=" + $(this).attr('id_producto')
        }).done(function(data) {
          loadMinicotizacion(true);
        })
      });

      $( '#limpiar_carrito' ).click(function(){
        $.ajax({
          method: "GET",
          url: "/accion_cotizacion.php?action=empty"
        }).done(function(data) {
          loadMinicotizacion(true);
        })
      });

      $( '#guardar_pedido' ).click(function(){
        var nombreFrame = 'intranet';
        var frame = document.getElementById('frame_cuenta').contentWindow.openFrame('guardar_cotizacion.php');
        frame.focus( );
      });
  }

  function showMiniCotizacion(){
    // Abrir el dropdown del carrito
    var btn = document.getElementById('open_shopping_cart');
    if (btn) {
      btn.classList.add('active');
      // Scroll al top para que se vea el carrito
      window.scrollTo({top: 0, behavior: 'smooth'});
    }
  }
</script>			<!--<script type="text/javascript" src="//www.computo.com.pe/livechat/php/app.php?widget-init.js"></script>-->

