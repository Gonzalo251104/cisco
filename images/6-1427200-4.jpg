<!-- WhatsApp flotante gestionado por mobile-optimized.css -->
	
	<body class="front_page cn-site-v4">
				
		<!-- - - - - - - - - - - - - - Main Wrapper - - - - - - - - - - - - - - - - -->
		<div class="wide_layout">
			<!-- - - - - - - - - - - - - - Header - - - - - - - - - - - - - - - - -->
			<header id="header" class="type_5 cn-store-header">
    <style>
        :root{
            --cn-navy: #063c5b;
            --cn-navy2: var(--cn-primary-hover, #044cb5);
            --cn-blue: var(--cn-primary, #005bd7);
            --cn-green: var(--cn-green, #079b3f);
            --cn-light: var(--cn-bg, #f6f9fd);
            --cn-white: #fff;
            --cn-text: var(--cn-text-color, #10264d);
        }
        .cn-store-header,.cn-store-header *{box-sizing:border-box}
        /* Reset: neutralizar estilos viejos de style.css que interfieren con el nuevo header */
        .cn-store-header input:not([type="submit"]){border:0!important;height:auto!important;width:auto!important;padding:0!important;background:none!important;color:inherit!important;border-radius:0!important}
        #header.type_5 #open_shopping_cart{height:36px!important;margin:0!important}
        #header.type_5 .site_settings{display:none!important}
        .cn-store-header{font-family:Roboto,Arial,sans-serif;background:var(--cn-navy);color:#fff;position:relative;z-index:1000;margin:0;padding:0;box-shadow:0 4px 18px rgba(0,28,76,.18)}
        .cn-store-header .top_part,.cn-store-header .middle_part,.cn-store-header .bottom_part,.cn-store-header .welcome_message,.cn-store-header .open_menu,.cn-store-header .main_product{display:none!important}
        .cn-store-top{background:var(--cn-navy);min-height:44px;display:grid;grid-template-columns:180px minmax(320px,920px) auto auto;align-items:center;gap:8px;padding:6px 50px}
        .cn-store-logo{display:flex;align-items:center}
        .cn-store-logo a{display:inline-flex;align-items:center;text-decoration:none}.cn-store-logo img{width:200px;max-width:100%;height:44px;object-fit:contain;display:block;background:transparent!important;border:none!important;border-radius:6px;padding:0}
        .cn-store-search{min-width:0;width:100%;max-width:920px;justify-self:center;margin:0 10px}.cn-store-search form{height:32px;display:flex;align-items:center;width:100%;background:#fff;border-radius:16px;overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,.08)}
        .cn-store-search .cn-search-icon-left{flex:0 0 38px;color:#111b2d;font-size:16px;text-align:center;display:flex;align-items:center;justify-content:center}.cn-store-header .cn-store-search input{height:36px!important;flex:1;border:0!important;outline:0!important;background:#fff!important;color:#1d2d44!important;padding:0 10px!important;font-size:13px!important;font-weight:500!important;box-shadow:none!important;width:auto!important;border-radius:0!important}.cn-store-header .cn-store-search input::placeholder{color:#777!important}.cn-store-search button{height:36px;flex:0 0 44px;border:0!important;background:#fff;color:var(--cn-navy);font-size:16px;display:flex;align-items:center;justify-content:center;cursor:pointer}
        .cn-store-actions{display:flex;align-items:center;gap:8px;white-space:nowrap}.cn-store-actions a{text-decoration:none!important;color:#fff!important;font-size:13px;font-weight:700}.cn-store-whatsapp{background:#079b3f!important;border-radius:6px;padding:0 14px!important;height:36px;display:inline-flex;align-items:center;gap:6px;box-shadow:0 4px 10px rgba(0,0,0,.15);color:#fff!important;font-size:13px;line-height:1.2}.cn-store-whatsapp i{font-size:18px}

        /* Estilos de botones de cabecera mejorados */
        .cn-header-btn{display:inline-flex;align-items:center;gap:6px;padding:0 14px;height:36px;border:1px solid rgba(255,255,255,.4);border-radius:6px;color:#fff!important;font-size:13px;font-weight:700;text-decoration:none!important;transition:all .2s ease;cursor:pointer;background:transparent;line-height:1.2;outline:none}
        .cn-header-btn:hover{background:rgba(255,255,255,.1);border-color:#fff;opacity:1!important}
        .cn-dropdown-wrapper{position:relative;display:inline-block}
        .cn-dropdown-menu{display:none;position:absolute;top:calc(100% + 8px);right:0;background:#fff;min-width:170px;border-radius:8px;box-shadow:0 8px 24px rgba(0,0,0,.15);z-index:1010;padding:6px 0;border:1px solid rgba(0,0,0,.08)}
        .cn-dropdown-menu::before{content:'';position:absolute;top:-6px;right:24px;border-left:6px solid transparent;border-right:6px solid transparent;border-bottom:6px solid #fff}
        .cn-dropdown-menu::after{content:'';position:absolute;top:-10px;left:0;right:0;height:10px;background:transparent}
        .cn-dropdown-menu a{display:flex!important;align-items:center!important;gap:8px!important;padding:8px 14px!important;color:#0d2a4f!important;font-size:13px!important;font-weight:700!important;text-decoration:none!important;transition:background .15s ease;text-align:left;line-height:1.2}
        .cn-dropdown-menu a:hover{background:#f0f6ff!important;color:#005bb8!important}
        .cn-dropdown-wrapper:hover .cn-dropdown-menu,
        .cn-dropdown-wrapper.is-active .cn-dropdown-menu{display:block}

        /* Estilos del carrito de compras (Cotización activa) */
        #responsive_car {
            position: relative;
            display: inline-flex;
            align-items: center;
            justify-content: flex-end;
            min-width: 132px;
            min-height: 36px;
            flex: 0 0 auto;
        }
        #open_shopping_cart {
            display: inline-flex !important;
            align-items: center;
            gap: 6px;
            padding: 0 14px 0 36px !important;
            height: 36px !important;
            border: 1px solid rgba(255, 255, 255, 0.4) !important;
            border-radius: 6px !important;
            background: transparent !important;
            color: #fff !important;
            font-size: 13px !important;
            font-weight: 700 !important;
            text-decoration: none !important;
            transition: all 0.2s ease;
            cursor: pointer;
            line-height: 1.2 !important;
            outline: none !important;
            margin: 0 !important;
            box-shadow: none !important;
            min-width: 132px !important;
        }
        #open_shopping_cart:hover,
        #open_shopping_cart.active {
            background: rgba(255, 255, 255, 0.1) !important;
            border-color: #fff !important;
            color: #fff !important;
        }
        #open_shopping_cart::before {
            content: '\f1c1' !important;
            font-family: 'FontAwesome' !important;
            color: #fff !important;
            font-size: 16px !important;
            position: absolute !important;
            left: 12px !important;
            top: 50% !important;
            transform: translateY(-50%) !important;
            margin-top: 0 !important;
            line-height: 1 !important;
        }
        #open_shopping_cart .title {
            display: none !important;
        }
        #open_shopping_cart .total_price {
            font-size: 13px !important;
            font-weight: 700 !important;
            color: #fff !important;
            display: inline-block !important;
            margin: 0 !important;
            line-height: 1.2 !important;
        }
        #open_shopping_cart::after {
            background: #ff3b30 !important;
            color: #fff !important;
            border: 1px solid var(--cn-navy) !important;
            font-size: 10px !important;
            font-weight: 800 !important;
            width: 18px !important;
            height: 18px !important;
            line-height: 16px !important;
            top: -4px !important;
            left: 22px !important;
            border-radius: 50% !important;
            text-align: center !important;
            display: block !important;
            position: absolute !important;
        }
        #responsive_car .shopping_cart.dropdown {
            display: none;
            position: absolute;
            top: calc(100% + 8px);
            right: 0;
            background: #fff;
            width: 320px;
            border-radius: 8px;
            box-shadow: 0 8px 24px rgba(0,0,0,0.15);
            z-index: 1010;
            padding: 16px;
            border: 1px solid rgba(0,0,0,0.08);
            color: #0d2a4f;
            text-align: left;
        }
        #responsive_car .shopping_cart.dropdown::before {
            content: '';
            position: absolute;
            top: -6px;
            right: 24px;
            border-left: 6px solid transparent;
            border-right: 6px solid transparent;
            border-bottom: 6px solid #fff;
        }
        #responsive_car .shopping_cart.dropdown::after {
            content: '';
            position: absolute;
            top: -10px;
            left: 0;
            right: 0;
            height: 10px;
            background: transparent;
        }
        #open_shopping_cart.active + .shopping_cart.dropdown,
        .shopping_cart.dropdown.visible {
            display: block !important;
        }

        /* ── Mini Carrito de Cotización: Contenido ── */
        .cn-mc-header{display:flex;align-items:center;justify-content:space-between;padding:0 0 10px;border-bottom:2px solid #e2e8f2;margin-bottom:4px}
        .cn-mc-title{font-size:14px;font-weight:800;color:#0d2a4f;display:flex;align-items:center;gap:6px}
        .cn-mc-title i{color:#005bd7;font-size:15px}
        .cn-mc-badge{background:#005bd7;color:#fff;font-size:11px;font-weight:800;padding:2px 8px;border-radius:10px}
        .cn-mc-items{max-height:260px;overflow-y:auto;padding:2px 0}
        .cn-mc-items::-webkit-scrollbar{width:4px}
        .cn-mc-items::-webkit-scrollbar-thumb{background:#c8d4e4;border-radius:4px}
        .cn-mc-item{display:grid;grid-template-columns:52px 1fr 24px;gap:10px;align-items:center;padding:10px 0;border-bottom:1px solid #f0f3f7}
        .cn-mc-item:last-child{border-bottom:0}
        .cn-mc-img{display:flex;align-items:center;justify-content:center;width:52px;height:52px;border:1px solid #e8edf3;border-radius:6px;overflow:hidden;background:#f8fafd;padding:2px;flex-shrink:0}
        .cn-mc-img img{width:48px!important;height:48px!important;max-width:48px!important;max-height:48px!important;object-fit:contain!important;display:block!important;border:0!important;padding:0!important;margin:0!important}
        .cn-mc-info{min-width:0;display:flex;flex-direction:column;gap:4px}
        .cn-mc-name{font-size:12px;font-weight:600;color:#10264d;text-decoration:none!important;line-height:1.35;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;text-overflow:ellipsis}
        .cn-mc-name:hover{color:#005bd7}
        .cn-mc-price-row{display:flex;align-items:center;gap:6px}
        .cn-mc-qty{font-size:11px;color:#6b7d99;font-weight:600}
        .cn-mc-price{font-size:12px;font-weight:800;color:#005bd7}
        .cn-mc-remove{width:24px;height:24px;border:0;background:#fff0f0;color:#d32f2f;border-radius:50%;font-size:12px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .15s ease;padding:0;line-height:1;flex-shrink:0}
        .cn-mc-remove:hover{background:#d32f2f;color:#fff;transform:scale(1.1)}
        .cn-mc-total{display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-top:2px solid #e2e8f2;margin-top:4px;font-size:13px;font-weight:700;color:#50627e}
        .cn-mc-total-price{font-size:16px;font-weight:900;color:#0d2a4f}
        .cn-mc-actions{display:flex;gap:8px;padding-top:4px}
        .cn-mc-btn-clear,.cn-mc-btn-quote{flex:1;display:inline-flex!important;align-items:center;justify-content:center;gap:5px;height:38px;border-radius:7px;font-size:12px;font-weight:800;text-decoration:none!important;cursor:pointer;transition:all .15s ease;border:0}
        .cn-mc-btn-clear{background:#f0f3f7;color:#555!important}
        .cn-mc-btn-clear:hover{background:#e2e6ec;color:#333!important}
        .cn-mc-btn-quote{background:linear-gradient(135deg,#005bd7,#0070e0);color:#fff!important;box-shadow:0 2px 8px rgba(0,91,215,.25)}
        .cn-mc-btn-quote:hover{background:linear-gradient(135deg,#044cb5,#005bd7);box-shadow:0 4px 12px rgba(0,91,215,.35)}
        .cn-mc-empty{padding:24px 10px;text-align:center}
        .cn-mc-empty i{font-size:36px;color:#c8d4e4;margin-bottom:10px}
        .cn-mc-empty p{margin:0 0 4px;font-size:14px;font-weight:700;color:#50627e}
        .cn-mc-empty span{font-size:11px;color:#8a99b0}

        /* Notificación de producto agregado */
        .cn-cart-toast{position:fixed;top:80px;right:20px;background:#fff;border:1px solid #dfe7f2;border-left:4px solid #079b3f;border-radius:8px;padding:14px 20px;box-shadow:0 8px 24px rgba(0,0,0,.15);z-index:9999;display:flex;align-items:center;gap:10px;font-family:Roboto,Arial,sans-serif;animation:cnToastIn .3s ease;max-width:340px}
        .cn-cart-toast i{color:#079b3f;font-size:20px}
        .cn-cart-toast span{font-size:13px;font-weight:700;color:#10264d}
        @keyframes cnToastIn{from{opacity:0;transform:translateX(30px)}to{opacity:1;transform:translateX(0)}}

        /* Estilos del panel de asesores WhatsApp */
        .cn-sales-wrap{position:relative;display:inline-flex;align-items:center}
        .cn-sales-panel{display:none;position:absolute;top:calc(100% + 12px);right:0;width:255px;background:var(--cn-navy);border-radius:0 0 12px 12px;padding:22px 18px 20px;box-shadow:0 14px 30px rgba(0,0,0,.28);z-index:3000;text-align:center;border:1px solid rgba(255,255,255,.08)}
        .cn-sales-panel.is-open{display:block}
        .cn-sales-panel:before{content:'';position:absolute;top:-8px;right:48px;border-left:8px solid transparent;border-right:8px solid transparent;border-bottom:8px solid var(--cn-navy)}
        .cn-sales-title{font-size:18px;font-weight:900;color:#fff;margin:0 0 16px;line-height:1.1}

        /* Panel Login / Registro / Recuperar (Multi-vista) */
        .cn-lp-view{display:none}
        .cn-lp-view.cn-lp-active{display:block}
        .cn-lp-input{width:100%;height:38px;padding:8px 12px;border:1px solid rgba(255,255,255,.25);border-radius:8px;background:rgba(255,255,255,.1);color:#fff;font-size:13px;font-weight:600;outline:none;transition:border-color .15s,background .15s}
        .cn-lp-input::placeholder{color:rgba(255,255,255,.45)}
        .cn-lp-input:focus{border-color:rgba(255,255,255,.5);background:rgba(255,255,255,.18)}
        .cn-lp-label{display:block;color:rgba(255,255,255,.75);font-size:11px;font-weight:700;margin-bottom:4px}
        .cn-lp-btn-primary{width:100%;height:40px;border:0;border-radius:8px;background:#fff;color:var(--cn-navy);font-size:14px;font-weight:800;cursor:pointer;transition:all .15s;display:flex;align-items:center;justify-content:center;gap:6px}
        .cn-lp-btn-primary:hover{background:#e8f0ff;transform:translateY(-1px)}
        .cn-lp-doc-msg{font-size:11px;font-weight:600;padding:4px 0;margin:0}
        .cn-sales-list{display:flex;flex-direction:column;gap:12px}
        .cn-sales-phone{display:flex!important;align-items:center!important;justify-content:center!important;gap:12px!important;background:#005a93!important;color:#fff!important;border-radius:8px!important;min-height:44px!important;padding:8px 12px!important;font-size:16px!important;font-weight:700!important;text-decoration:none!important;box-shadow:none!important}
        .cn-sales-phone:hover{background:#0080cc!important;color:#fff!important}
        .cn-sales-phone i{font-size:20px;color:#13d86b}
        .cn-sales-phone.cn-sales-landline i{color:#fff}

        /* Estilos de Menú Móvil Hamburguesa */
        .cn-mobile-menu-trigger{display:none;background:transparent;border:0;color:#fff;font-size:26px;cursor:pointer;align-items:center;justify-content:center;padding:8px;outline:none}
        .cn-mobile-menu-dropdown{display:none;background:#005a93;border-top:1px solid rgba(255,255,255,.1);padding:18px 24px;flex-direction:column;gap:14px}
        .cn-mobile-menu-dropdown.is-open{display:flex}
        .cn-mobile-item-link{display:flex;align-items:center;gap:10px;color:#fff!important;text-decoration:none!important;font-size:15px;font-weight:700;padding:12px 16px;border-radius:8px;background:rgba(255,255,255,.05);transition:background .2s ease}
        .cn-mobile-item-link:hover{background:rgba(255,255,255,.1)}
        .cn-mobile-whatsapp-list{margin:6px 0 0 12px;padding:0;list-style:none;display:flex;flex-direction:column;gap:10px;border-left:2px solid rgba(255,255,255,.15);padding-left:14px}
        .cn-mobile-whatsapp-list a{display:flex;align-items:center;gap:10px;color:rgba(255,255,255,.9)!important;text-decoration:none!important;font-size:14px;font-weight:700;padding:6px 0}
        .cn-mobile-whatsapp-list a:hover{color:#fff!important}
        .cn-mobile-whatsapp-list a i{font-size:18px;color:#13d86b}
        .cn-mobile-whatsapp-list a.cn-mobile-landline i{color:#fff}
        .cn-mobile-submenu-title{font-size:11px;text-transform:uppercase;color:rgba(255,255,255,.5);font-weight:800;margin:12px 0 2px 4px;letter-spacing:1px}

        .cn-store-cats{background:var(--cn-light);color:var(--cn-text);min-height:34px;display:flex;align-items:center;justify-content:center;padding:6px 42px;border-top:1px solid var(--cn-border-color);border-bottom:1px solid var(--cn-border-color)}.cn-store-cats ul{display:flex;align-items:center;justify-content:center;flex-wrap:wrap;gap:0;margin:0!important;padding:0!important;list-style:none!important}.cn-store-cats li{list-style:none!important;margin:0!important;padding:0!important;display:flex;align-items:center}.cn-store-cats li+li:before{content:'▪';font-size:10px;color:var(--cn-navy);margin:0 14px 0 12px}.cn-store-cats a{color:var(--cn-navy)!important;text-decoration:none!important;font-size:13px;font-weight:700;line-height:1.2}.cn-store-cats a:hover{color:#0065c9!important;text-decoration:underline!important}

        /* ── Búsqueda Predictiva Dropdown ── */
        #sugerencias-busqueda{font-family:Roboto,Arial,sans-serif}
        .bp-box{background:#fff;border-radius:12px;box-shadow:0 12px 40px rgba(0,20,60,.18),0 2px 8px rgba(0,20,60,.08);border:1px solid rgba(0,40,120,.08);overflow:hidden;animation:bpFadeIn .18s ease}
        @keyframes bpFadeIn{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:translateY(0)}}
        .bp-item{display:flex!important;align-items:center;gap:14px;padding:10px 16px;text-decoration:none!important;color:#1a2a44!important;border-bottom:1px solid #f0f3f7;transition:background .12s ease}
        .bp-item:last-of-type{border-bottom:none}
        .bp-item:hover,.bp-item:focus{background:linear-gradient(90deg,#eef4ff 0%,#f8faff 100%)}
        .bp-img{width:52px;height:52px;object-fit:contain;border-radius:8px;background:#f8fafd;border:1px solid #e8edf3;flex-shrink:0;padding:3px}
        .bp-info{flex:1;min-width:0;display:flex;flex-direction:column;gap:2px}
        .bp-nombre{font-size:13px;font-weight:600;color:#0d2a4f;line-height:1.35;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;text-overflow:ellipsis}
        .bp-meta{font-size:11px;color:#6b7d99;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
        .bp-precio{font-size:14px;font-weight:800;color:#005bd7;white-space:nowrap;margin-top:1px}
        .bp-ver-todos{text-align:center;padding:10px 16px;font-size:12px;font-weight:700;color:#5a6f8a;background:#f6f9fd;border-top:1px solid #eaeff5;letter-spacing:.2px}
        .bp-ver-todos i{margin-right:4px}

        @media(max-width:768px){
            .bp-img{width:44px;height:44px}
            .bp-item{padding:9px 12px;gap:10px}
            .bp-nombre{font-size:12px;-webkit-line-clamp:1}
            .bp-precio{font-size:13px}
            .bp-meta{font-size:10px}
        }

        /* Responsividad general */
        @media(max-width:1280px){
            .cn-store-top{grid-template-columns:190px minmax(320px,760px) auto auto;padding:16px 28px;gap:8px}
            .cn-store-logo img{width:180px}
            .cn-store-actions{gap:8px}
            .cn-header-btn{padding:0 12px;font-size:13px}
            .cn-store-whatsapp{padding:0 12px!important;font-size:13px}
        }
        @media(max-width:980px){
            .cn-store-top{grid-template-columns:1fr;gap:13px;text-align:center}
            .cn-store-logo a{justify-content:center}
            .cn-store-search{width:100%;max-width:100%;justify-self:stretch}
            .cn-store-actions{justify-content:center;flex-wrap:wrap}
            .cn-store-cats{justify-content:flex-start;overflow-x:auto;padding:9px 16px}
            .cn-store-cats ul{flex-wrap:nowrap;justify-content:flex-start}
            .cn-store-cats a{white-space:nowrap}
            .cn-sales-panel{right:50%;transform:translateX(50%);top:calc(100% + 10px)}.cn-sales-panel:before{right:50%;transform:translateX(50%)}
        }
        @media(max-width:768px){
            .cn-store-top{grid-template-columns:1fr auto auto!important;padding:12px 16px;gap:12px;text-align:left}
            .cn-store-logo a{justify-content:flex-start}
            .cn-store-logo img{width:150px}
            .cn-store-logo{grid-row:1;grid-column:1;}
            #responsive_car{grid-row:1;grid-column:2;align-self:center;}
            .cn-mobile-menu-trigger{grid-row:1;grid-column:3;display:inline-flex!important;align-self:center;}
            .cn-store-search{grid-row:2;grid-column:1 / -1;margin-top:4px}
            .cn-store-actions{display:none!important}
            
            #open_shopping_cart {
                height: 38px !important;
                padding: 0 10px 0 32px !important;
            }
            #open_shopping_cart::before {
                left: 10px !important;
                font-size: 16px !important;
            }
            #open_shopping_cart .total_price {
                display: none !important;
            }
            #open_shopping_cart::after {
                left: 20px !important;
                top: -2px !important;
            }
        }
        @media(max-width:560px){
            .cn-store-top{padding:12px 12px}
            .cn-store-logo img{width:130px}
            .cn-store-search form{height:42px}
            .cn-store-search input{font-size:13px!important}
        }
    </style>
